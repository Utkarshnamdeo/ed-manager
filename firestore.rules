rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuthenticated() && me().active == true;
    }

    function role() {
      return me().role;
    }

    function isAdmin() {
      return isActive() && role() == 'admin';
    }

    function isStaff() {
      return isActive() && role() == 'staff';
    }

    function isTeacher() {
      return isActive() && role() == 'teacher';
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function can(flag) {
      return isActive() && me().permissions.get(flag, false) == true;
    }

    function teacherOwnsSession(sessionId) {
      let session = get(/databases/$(database)/documents/classSessions/$(sessionId)).data;
      return session.teacherId == me().teacherId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if isAdminOrStaff() || isTeacher();
      allow create, update: if isAdmin() || (isStaff() && can('manageStudents'));
      allow delete: if false;
    }

    match /memberships/{membershipId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageStudents'));
      allow delete: if false;
    }

    match /teachers/{teacherId} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isStaff() && can('manageTeachers'));
      allow delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isStaff() && can('manageRooms'));
      allow delete: if false;
    }

    match /classTemplates/{templateId} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isStaff() && can('manageClasses'));
      allow delete: if false;
    }

    match /classSessions/{sessionId} {
      allow read: if isActive();
      allow create, update: if isAdmin() || (isStaff() && can('manageClasses'));
      allow delete: if false;
    }

    match /attendanceRecords/{recordId} {
      allow read: if isAdminOrStaff() ||
        (isTeacher() && teacherOwnsSession(resource.data.sessionId));
      allow create, update, delete: if false;
    }

    match /backupLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /config/{configId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() && can('configureSystem');
      allow delete: if false;
    }
  }
}
