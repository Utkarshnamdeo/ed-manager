rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return isAuthenticated() && me().active == true;
    }

    function role() {
      return me().role;
    }

    function isAdmin() {
      return isActive() && role() == 'admin';
    }

    function isStaff() {
      return isActive() && role() == 'staff';
    }

    function isAdminOrStaff() {
      return isAdmin() || isStaff();
    }

    function can(flag) {
      return isActive() && me().permissions.get(flag, false) == true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageStudents'));
      allow delete: if isAdmin();
    }

    match /memberships/{membershipId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageStudents'));
      allow delete: if isAdmin();
    }

    match /classCards/{cardId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageStudents'));
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageTeachers'));
      allow delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageRooms'));
      allow delete: if isAdmin();
    }

    match /classTemplates/{templateId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageClasses'));
      allow delete: if isAdmin();
    }

    match /classSessions/{sessionId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() || (isStaff() && can('manageClasses'));
      allow delete: if isAdmin();
    }

    match /attendanceRecords/{recordId} {
      allow read: if isAdminOrStaff();
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isAdminOrStaff();
      allow create, update: if isAdmin() && can('configureSystem');
      allow delete: if false;
    }
  }
}
